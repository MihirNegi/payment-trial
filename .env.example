# ===========================================
# Razorpay (Cards, Net Banking, Wallets, EMI)
# Currently commented out — uncomment when ready
# ===========================================
# RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
# RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ===========================================
# Zaakpay / MobiKwik (All payment methods)
# ===========================================
# Get these from https://zaakpay.com dashboard
ZAAKPAY_MERCHANT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZAAKPAY_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZAAKPAY_ENCRYPTION_KEY_ID=XXXXXXXXXXXXXXX
# Public key for RSA encryption of card details (PEM format, from Zaakpay dashboard)
ZAAKPAY_PUBLIC_KEY=""
# Set to "staging" for testing, "live" for production
ZAAKPAY_ENV=staging

# ===========================================
# App Configuration
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3333
